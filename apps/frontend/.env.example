# ============================================
# FRONTEND PRODUCTION ENVIRONMENT VARIABLES
# ============================================

# Backend API URL
# For EC2 without SSL:
VITE_API_URL=http://YOUR_EC2_PUBLIC_IP:3000

# For EC2 with SSL (recommended):
# VITE_API_URL=https://api.yourdomain.com

# For local testing:
# VITE_API_URL=http://localhost:3000

# Optional: dedicated Socket server URL (if different from API origin)
# VITE_SOCKET_URL=http://YOUR_EC2_PUBLIC_IP:3000

# ============================================
# SEED DEMO IMAGE (Backend seed.ts)
# ============================================
# Dùng khi bạn chạy `npx prisma db seed` trên server để lấy ảnh từ Pexels.
# Biến này được đọc bởi apps/backend/prisma/seed.ts (không dùng ở runtime frontend).
PEXELS_API_KEY=your_pexels_api_key


# For testing:
# VITE_STRIPE_PUBLIC_KEY=pk_test_your_stripe_test_key
# FRONTEND
VITE_API_URL=http://localhost:3000/api/v1
VITE_SOCKET_URL=http://localhost:3000